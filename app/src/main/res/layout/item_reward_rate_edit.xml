<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Category name -->
        <TextView
            android:id="@+id/tv_edit_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/et_edit_rate" />

        <!-- Rate type label (e.g. "x Points") -->
        <TextView
            android:id="@+id/tv_rate_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginStart="4dp"
            app:layout_constraintTop_toTopOf="@id/et_edit_rate"
            app:layout_constraintBottom_toBottomOf="@id/et_edit_rate"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Editable rate value -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_edit_rate"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_rate_type_label">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_edit_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:gravity="center" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Choice category indicator -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_choice_category"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Choice Category"
            android:visibility="gone"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            app:layout_constraintTop_toBottomOf="@id/tv_edit_category"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Customized indicator -->
        <TextView
            android:id="@+id/tv_customized_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Customized"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_edit_category"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
