<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Divider above (except first item — handled in adapter) -->
    <View
        android:id="@+id/divider_rb"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="?attr/colorOutlineVariant" />

    <!-- Card name + Mark Done + Remove -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_rb_card_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_rb_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:alpha="0.8" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rb_mark_done"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark Done"
            android:textColor="@color/success_green"
            android:minWidth="0dp"
            app:strokeColor="@color/success_green" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rb_delete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove"
            android:textColor="@color/design_default_color_error"
            android:minWidth="0dp" />

    </LinearLayout>

    <!-- Categories -->
    <TextView
        android:id="@+id/tv_rb_categories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSecondaryContainer" />

    <!-- Seek bar -->
    <SeekBar
        android:id="@+id/seekbar_rb_usage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"
        android:progressTint="?attr/colorOnSecondaryContainer"
        android:thumbTint="?attr/colorOnSecondaryContainer" />

    <!-- Bottom: Expires (left) | Spent/limit (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_rb_end_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:alpha="0.7" />

        <TextView
            android:id="@+id/tv_rb_used_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:alpha="0.8" />

    </LinearLayout>

</LinearLayout>
